model User {
    id         String    @id @default(auto()) @map("_id") @db.ObjectId
    name       String
    password   String
    email      String    @unique
    role       Role      @default(USER)
    country    String?
    profession String?
    avatar     String?
    isVerified Boolean   @default(false)
    comment    comment[]
}

enum Role {
    USER
    ADMIN
    MENTOR
}

model comment {
    id      String @id @default(auto()) @map("_id") @db.ObjectId
    content String
    rating  Int
    givenBy String
    user    User   @relation(fields: [userId], references: [id])
    userId  String @db.ObjectId
}
